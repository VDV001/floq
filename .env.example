APP_PORT=8080
APP_ENV=development

DATABASE_URL=postgres://floq:floq@localhost:5432/floq?sslmode=disable
REDIS_URL=redis://localhost:6379

JWT_SECRET=change-me
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# AI Provider: claude | openai | groq | ollama
AI_PROVIDER=claude

ANTHROPIC_API_KEY=sk-ant-...

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

GROQ_API_KEY=gsk_...
GROQ_MODEL=openai/gpt-oss-120b

TELEGRAM_BOT_TOKEN=...

RESEND_API_KEY=re_...

# SMTP (alternative to Resend — mail.ru, Yandex, Gmail, etc.)
SMTP_HOST=smtp.mail.ru
SMTP_PORT=465
SMTP_USER=hello@yourdomain.com
SMTP_PASSWORD=...
SMTP_FROM=hello@yourdomain.com

IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=...
IMAP_PASSWORD=...

# Sender identity (used in TG outreach prompts)
SENDER_NAME=Имя
SENDER_COMPANY=company.com
