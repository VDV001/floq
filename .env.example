APP_PORT=8080
APP_ENV=development

DATABASE_URL=postgres://floq:floq@localhost:5432/floq?sslmode=disable
REDIS_URL=redis://localhost:6379

JWT_SECRET=change-me
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# At-rest encryption key (KEK) for client credentials (IMAP/SMTP passwords,
# API keys, the 1C auth secret). MUST be base64-encoded 32 bytes — the server
# refuses to start otherwise (no silent plaintext fallback). Generate with:
#   openssl rand -base64 32
# Keep this OUT of version control and back it up: losing it makes every
# stored secret unrecoverable.
FLOQ_SECRETS_KEK=

# Auth rate limits (per client IP). Login: AUTH_LOGIN_RATE_LIMIT attempts
# per 5 min. Register: AUTH_REGISTER_RATE_LIMIT sign-ups per hour.
AUTH_LOGIN_RATE_LIMIT=5
AUTH_REGISTER_RATE_LIMIT=3
# Trust X-Forwarded-For / X-Real-IP when resolving the client IP. Leave
# false unless a reverse proxy that OVERWRITES these headers sits in
# front of the app — otherwise the per-IP rate limit is spoofable.
TRUST_PROXY=false

# Audit-log retention. Per-call rows older than AUDIT_RETENTION_DAYS are
# rolled up into audit_log_daily and deleted; the cron runs every
# AUDIT_RETENTION_INTERVAL.
AUDIT_RETENTION_DAYS=30
AUDIT_RETENTION_INTERVAL=24h

# AI Provider: claude | openai | groq | ollama
AI_PROVIDER=claude

ANTHROPIC_API_KEY=sk-ant-...

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

GROQ_API_KEY=gsk_...
GROQ_MODEL=openai/gpt-oss-120b

TELEGRAM_BOT_TOKEN=...

RESEND_API_KEY=re_...

# SMTP (alternative to Resend — mail.ru, Yandex, Gmail, etc.)
SMTP_HOST=smtp.mail.ru
SMTP_PORT=465
SMTP_USER=hello@yourdomain.com
SMTP_PASSWORD=...
SMTP_FROM=hello@yourdomain.com

IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=...
IMAP_PASSWORD=...

# Sender identity (used in TG outreach prompts)
SENDER_NAME=Имя
SENDER_COMPANY=company.com

# ── Auto-enrichment ────────────────────────────────────────────────────────
# Phase 1 (#182): a background worker scrapes a lead/prospect's company website
# (domain from their email) into a "company" card. Tunables (all optional):
ENRICHMENT_REFRESH_INTERVAL=1m      # worker tick
ENRICHMENT_TTL_DAYS=30              # how long an enriched record stays fresh
ENRICHMENT_MAX_ATTEMPTS=3          # give up after this many failures
ENRICHMENT_BATCH_LIMIT=20          # rows scraped per tick
ENRICHMENT_RATE_LIMIT_PER_MIN=10  # per-domain scrape budget per minute

# Phase 2 (#186): LLM classifies industry/company_size from the scraped page.
# Ship-dark: off by default; reuses the configured AI provider (cost is audited
# under request_type='enrichment'). Bounded by Budget mode + token/input caps.
ENRICHMENT_LLM_ENABLED=false
ENRICHMENT_LLM_MAX_INPUT_RUNES=8000
ENRICHMENT_LLM_MAX_TOKENS=64

# Phase 3 (#188): legal details (ИНН/ОГРН/адрес/ОКВЭД) via the official DaData
# API. Ship-dark: disabled unless ENABLED=true AND a key is set. The global
# rate limit protects the shared daily quota.
ENRICHMENT_REGISTRY_ENABLED=false
DADATA_API_KEY=
ENRICHMENT_REGISTRY_RATE_LIMIT_PER_MIN=30
